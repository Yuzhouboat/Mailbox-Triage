# Copy this file to `~/mailbox-triage/mailbox-triage-config.toml`.

# Optional. Which mailbox backend(s) are configured.
# If only one section is present below, that backend is used automatically.
# If both [exchange] and [gmail] sections are present, the skill will ask the user
# which mailbox to triage at the start of each session.
# You can also override at runtime by saying "triage my Gmail" or "triage Exchange".

[exchange]
server = "exchange.example.com"
username = "mailbox@example.com"
password = "replace-me"

# Optional. The address of the mailbox you want to open (the inbox to triage).
# Defaults to `username` when omitted.
#   - Triaging YOUR OWN mailbox: remove this line (or leave it equal to `username`).
#   - Triaging a SHARED/DELEGATED mailbox: set this to the shared mailbox address,
#     while `username`/`password` above stay as YOUR login credentials.
primary_smtp_address = "mailbox@example.com"

# Optional. Whether to auto-detect Exchange server settings from the email address.
# Defaults to false.
#   - Keep false when `server` above is set to a known host (recommended, faster).
#   - Set true only if you do NOT know the server and want exchangelib to discover it
#     (slower, and may fail behind locked-down corporate DNS).
autodiscover = false

[gmail]
# No password needed — authentication is OAuth via the Gmail MCP tool.
# See references/gmail-authentication.md for the auth flow.
primary_smtp_address = "you@gmail.com"   # optional, informational only

# Optional. Used when filing classified messages into folders (Exchange) or labels (Gmail).
# By default each group is filed using the group name as-is.
# Add entries here to override the folder/label name for specific groups,
# or to use a slash-delimited path (Exchange subfolder / Gmail nested label).
# Keys are group names from triage-rules.md; values are folder or label names/paths.
# Exchange: folders must already exist; the script never creates them.
# Gmail: missing labels are created automatically.
[group_folders]
# "Distribution alerts" = "Inbox/Triage/Distribution alerts"
# "Uncategorized" = "Inbox/Triage/Uncategorized"
